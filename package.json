{
  "name": "numbernavigator",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build:content-script:chrome": "tsc ./src/content.ts --outDir ./dist/numbernavigator/chrome --target es2020 --module commonjs --lib \"ES2020\",\"DOM\"",
    "build:content-script:firefox": "tsc ./src/content.ts --outDir ./dist/numbernavigator/firefox --target es2020 --module esnext --lib \"ES2020\",\"DOM\"",
    "build:background-script:chrome": "tsc ./src/background.ts --outDir ./dist/numbernavigator/chrome --target es2020 --module commonjs --lib \"ES2020\",\"DOM\"",
    "build:background-script:firefox": "tsc ./src/background.ts --outDir ./dist/numbernavigator/firefox --target es2020 --module esnext --lib \"ES2020\",\"DOM\"",
    "build:chrome": "ng build --output-path dist/numbernavigator/chrome && npm run build:background-script:chrome && npm run build:content-script:chrome",
    "build:firefox": "ng build --output-path dist/numbernavigator/firefox && npm run build:background-script:firefox && npm run build:content-script:firefox",
    "zip:chrome": "cd dist/numbernavigator/chrome && zip -r ../../numbernavigator-chrome.zip .",
    "zip:firefox": "cd dist/numbernavigator/firefox && zip -r ../../numbernavigator-firefox.zip .",
    "zip": "npm run zip:chrome && npm run zip:firefox",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "~20.0.0",
    "@angular/compiler": "~20.0.0",
    "@angular/core": "~20.0.0",
    "@angular/forms": "~20.0.0",
    "@angular/platform-browser": "~20.0.0",
    "@angular/platform-browser-dynamic": "~20.0.0",
    "@angular/router": "~20.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^19.0.1",
    "@angular-devkit/build-angular": "~20.0.0",
    "@angular/cli": "~20.0.0",
    "@angular/compiler-cli": "~20.0.0",
    "@types/chrome": "^0.0.323",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.8.0"
  }
}
